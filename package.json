{
  "name": "minierp",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "bun run --filter server db:generate",
    "db:migrate": "bun run --filter server db:migrate",
    "db:seed": "bun run --filter server db:seed",
    "daily": "./project.sh all start",
    "project": "./project.sh",
    "user-stories:verify": "bun scripts/verify-user-stories.ts",
    "ralph": "bun scripts/ralph/runner.ts"
  },
  "devDependencies": {
    "server": "workspace:*",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "bun@1.2.9",
  "dependencies": {
    "@types/jsonwebtoken": "9.0.6",
    "codex": "^0.2.3",
    "jsonwebtoken": "9.0.2"
  }
}
