generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EvidenceScope {
  document
  line
}

model Tenant {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @default("system") @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @default("system") @map("updated_by")

  @@map("tenant")
}

model User {
  id           BigInt    @id @default(autoincrement())
  tenantId     BigInt    @map("tenant_id")
  username     String
  email        String
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  createdBy    String    @default("system") @map("created_by")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  updatedBy    String    @default("system") @map("updated_by")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")

  @@unique([tenantId, username])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("user")
}

model Role {
  id        BigInt   @id @default(autoincrement())
  tenantId  BigInt   @map("tenant_id")
  code      String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @default("system") @map("created_by")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @default("system") @map("updated_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("role")
}

model Permission {
  id        BigInt   @id @default(autoincrement())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("permission")
}

model UserRole {
  id        BigInt   @id @default(autoincrement())
  tenantId  BigInt   @map("tenant_id")
  userId    BigInt   @map("user_id")
  roleId    BigInt   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, userId])
  @@map("user_role")
}

model ApiClient {
  id               BigInt   @id @default(autoincrement())
  tenantId         BigInt   @map("tenant_id")
  clientId         String   @map("client_id")
  clientSecretHash String   @map("client_secret_hash")
  scopes           String
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, clientId])
  @@index([tenantId])
  @@map("api_client")
}

model ApiCallLog {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt   @map("tenant_id")
  clientId   String   @map("client_id")
  path       String
  method     String
  statusCode Int      @map("status_code")
  requestId  String?  @map("request_id")
  calledAt   DateTime @default(now()) @map("called_at")

  @@index([tenantId, calledAt])
  @@map("api_call_log")
}

model Company {
  id          BigInt    @id @default(autoincrement())
  tenantId    BigInt    @map("tenant_id")
  companyCode String    @map("company_code")
  companyName String    @map("company_name")
  status      String    @default("active")
  ext         Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @default("system") @map("created_by")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedBy   String    @default("system") @map("updated_by")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by")

  @@unique([tenantId, companyCode])
  @@index([tenantId, status])
  @@map("company")
}

model OrgUnit {
  id          BigInt    @id @default(autoincrement())
  tenantId    BigInt    @map("tenant_id")
  companyId   BigInt?   @map("company_id")
  orgCode     String    @map("org_code")
  orgName     String    @map("org_name")
  parentOrgId BigInt?   @map("parent_org_id")
  status      String    @default("active")
  ext         Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @default("system") @map("created_by")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedBy   String    @default("system") @map("updated_by")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by")

  @@unique([tenantId, companyId, orgCode])
  @@index([tenantId, companyId, status])
  @@map("org_unit")
}

model RolePermission {
  id           BigInt   @id @default(autoincrement())
  tenantId     BigInt   @map("tenant_id")
  roleId       BigInt   @map("role_id")
  permissionId BigInt   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String   @default("system") @map("created_by")

  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId, roleId])
  @@map("role_permission")
}

model UserOrgScope {
  id        BigInt   @id @default(autoincrement())
  tenantId  BigInt   @map("tenant_id")
  userId    BigInt   @map("user_id")
  orgId     BigInt   @map("org_id")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String   @default("system") @map("created_by")

  @@unique([tenantId, userId, orgId])
  @@index([tenantId, userId])
  @@map("user_org_scope")
}

model Uom {
  id        BigInt    @id @default(autoincrement())
  tenantId  BigInt    @map("tenant_id")
  companyId BigInt?   @map("company_id")
  orgId     BigInt?   @map("org_id")
  uomCode   String    @map("uom_code")
  uomName   String    @map("uom_name")
  precision Int?
  status    String    @default("active")
  ext       Json?
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String    @default("system") @map("created_by")
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String    @default("system") @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@unique([tenantId, companyId, uomCode])
  @@index([tenantId, companyId, status])
  @@map("uom")
}

model TaxCode {
  id           BigInt    @id @default(autoincrement())
  tenantId     BigInt    @map("tenant_id")
  companyId    BigInt?   @map("company_id")
  orgId        BigInt?   @map("org_id")
  taxCode      String    @map("tax_code")
  taxName      String    @map("tax_name")
  taxType      String    @map("tax_type")
  rate         Decimal   @db.Decimal(20, 6)
  inclusive    Boolean   @default(false)
  jurisdiction String?
  status       String    @default("active")
  ext          Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  createdBy    String    @default("system") @map("created_by")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  updatedBy    String    @default("system") @map("updated_by")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by")

  @@unique([tenantId, companyId, taxCode])
  @@index([tenantId, companyId, status])
  @@map("tax_code")
}

model Sku {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  companyId     BigInt?   @map("company_id")
  orgId         BigInt?   @map("org_id")
  skuCode       String    @map("sku_code")
  name          String
  specification String?
  categoryId    String?   @map("category_id")
  unit          String?
  uomCode       String?   @map("uom_code")
  itemType      String?   @map("item_type")
  taxCodeId     BigInt?   @map("tax_code_id")
  taxRate       Decimal?  @map("tax_rate") @db.Decimal(20, 6)
  barcode       String?
  batchManaged  Boolean   @default(false) @map("batch_managed")
  serialManaged Boolean   @default(false) @map("serial_managed")
  shelfLifeDays Int?      @map("shelf_life_days")
  minStockQty   Decimal?  @map("min_stock_qty") @db.Decimal(20, 6)
  maxStockQty   Decimal?  @map("max_stock_qty") @db.Decimal(20, 6)
  leadTimeDays  Int?      @map("lead_time_days")
  status        String    @default("active")
  ext           Json?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String    @default("system") @map("created_by")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  updatedBy     String    @default("system") @map("updated_by")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     String?   @map("deleted_by")

  @@unique([tenantId, skuCode])
  @@index([tenantId, isActive])
  @@map("sku")
}

model SkuMapping {
  id           BigInt   @id @default(autoincrement())
  tenantId     BigInt   @map("tenant_id")
  companyId    BigInt?  @map("company_id")
  orgId        BigInt?  @map("org_id")
  skuId        BigInt   @map("sku_id")
  sourceType   String   @map("source_type")
  externalCode String   @map("external_code")
  isPrimary    Boolean  @default(false) @map("is_primary")
  ext          Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([tenantId, sourceType, externalCode])
  @@index([tenantId, skuId])
  @@map("sku_mapping")
}

model SkuSubstitution {
  id              BigInt   @id @default(autoincrement())
  tenantId        BigInt   @map("tenant_id")
  companyId       BigInt?  @map("company_id")
  orgId           BigInt?  @map("org_id")
  skuId           BigInt   @map("sku_id")
  substituteSkuId BigInt   @map("substitute_sku_id")
  ext             Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([tenantId, skuId, substituteSkuId])
  @@index([tenantId, skuId])
  @@map("sku_substitution")
}

model Item {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  companyId     BigInt?   @map("company_id")
  orgId         BigInt?   @map("org_id")
  itemCode      String    @map("item_code")
  itemName      String    @map("item_name")
  specModel     String?   @map("spec_model")
  itemType      String?   @map("item_type")
  categoryId    String?   @map("category_id")
  uomCode       String    @map("uom_code")
  taxCodeId     BigInt?   @map("tax_code_id")
  taxRate       Decimal?  @map("tax_rate") @db.Decimal(20, 6)
  barcode       String?
  batchManaged  Boolean   @default(false) @map("batch_managed")
  serialManaged Boolean   @default(false) @map("serial_managed")
  shelfLifeDays Int?      @map("shelf_life_days")
  minStockQty   Decimal?  @map("min_stock_qty") @db.Decimal(20, 6)
  maxStockQty   Decimal?  @map("max_stock_qty") @db.Decimal(20, 6)
  leadTimeDays  Int?      @map("lead_time_days")
  status        String    @default("active")
  ext           Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String    @default("system") @map("created_by")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  updatedBy     String    @default("system") @map("updated_by")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     String?   @map("deleted_by")

  @@unique([tenantId, itemCode])
  @@index([tenantId, companyId, status])
  @@map("item")
}

model ItemMapping {
  id           BigInt   @id @default(autoincrement())
  tenantId     BigInt   @map("tenant_id")
  companyId    BigInt?  @map("company_id")
  orgId        BigInt?  @map("org_id")
  itemId       BigInt   @map("item_id")
  sourceType   String   @map("source_type")
  externalCode String   @map("external_code")
  isPrimary    Boolean  @default(false) @map("is_primary")
  ext          Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([tenantId, sourceType, externalCode])
  @@index([tenantId, itemId])
  @@map("item_mapping")
}

model ItemSubstitution {
  id               BigInt   @id @default(autoincrement())
  tenantId         BigInt   @map("tenant_id")
  companyId        BigInt?  @map("company_id")
  orgId            BigInt?  @map("org_id")
  itemId           BigInt   @map("item_id")
  substituteItemId BigInt   @map("substitute_item_id")
  ext              Json?
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([tenantId, itemId, substituteItemId])
  @@index([tenantId, itemId])
  @@map("item_substitution")
}

model Warehouse {
  id            BigInt    @id @default(autoincrement())
  tenantId      BigInt    @map("tenant_id")
  companyId     BigInt?   @map("company_id")
  orgId         BigInt?   @map("org_id")
  code          String
  name          String
  warehouseType String?   @map("warehouse_type")
  address       String?
  contactPerson String?   @map("contact_person")
  contactPhone  String?   @map("contact_phone")
  manageBin     Boolean   @default(false) @map("manage_bin")
  status        String    @default("active")
  ext           Json?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String    @default("system") @map("created_by")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  updatedBy     String    @default("system") @map("updated_by")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     String?   @map("deleted_by")

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("warehouse")
}

model WarehouseBin {
  id          BigInt    @id @default(autoincrement())
  tenantId    BigInt    @map("tenant_id")
  companyId   BigInt?   @map("company_id")
  orgId       BigInt?   @map("org_id")
  warehouseId BigInt    @map("warehouse_id")
  binCode     String    @map("bin_code")
  binName     String    @map("bin_name")
  zoneCode    String?   @map("zone_code")
  binType     String?   @map("bin_type")
  status      String    @default("active")
  ext         Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @default("system") @map("created_by")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedBy   String    @default("system") @map("updated_by")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by")

  @@unique([tenantId, warehouseId, binCode])
  @@index([tenantId, warehouseId, status])
  @@map("warehouse_bin")
}

model Supplier {
  id               BigInt    @id @default(autoincrement())
  tenantId         BigInt    @map("tenant_id")
  companyId        BigInt?   @map("company_id")
  orgId            BigInt?   @map("org_id")
  code             String
  name             String
  taxpayerIdOrUscc String?   @map("taxpayer_id_or_uscc")
  payeeBank        String?   @map("payee_bank")
  payeeAccount     String?   @map("payee_account")
  contactName      String?   @map("contact_name")
  contactMobile    String?   @map("contact_mobile")
  phone            String?
  email            String?
  address          String?
  paymentTerm      String?   @map("payment_term")
  defaultTaxCodeId BigInt?   @map("default_tax_code_id")
  status           String    @default("active")
  ext              Json?
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  createdBy        String    @default("system") @map("created_by")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  updatedBy        String    @default("system") @map("updated_by")
  deletedAt        DateTime? @map("deleted_at")
  deletedBy        String?   @map("deleted_by")

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("supplier")
}

model Customer {
  id               BigInt    @id @default(autoincrement())
  tenantId         BigInt    @map("tenant_id")
  companyId        BigInt?   @map("company_id")
  orgId            BigInt?   @map("org_id")
  code             String
  name             String
  taxpayerIdOrUscc String?   @map("taxpayer_id_or_uscc")
  invoiceTitle     String?   @map("invoice_title")
  billingAddress   String?   @map("billing_address")
  billingPhone     String?   @map("billing_phone")
  bankName         String?   @map("bank_name")
  bankAccount      String?   @map("bank_account")
  contactName      String?   @map("contact_name")
  contactMobile    String?   @map("contact_mobile")
  phone            String?
  email            String?
  address          String?
  creditLimit      Decimal?  @map("credit_limit") @db.Decimal(20, 6)
  paymentTerm      String?   @map("payment_term")
  defaultTaxCodeId BigInt?   @map("default_tax_code_id")
  status           String    @default("active")
  ext              Json?
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  createdBy        String    @default("system") @map("created_by")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  updatedBy        String    @default("system") @map("updated_by")
  deletedAt        DateTime? @map("deleted_at")
  deletedBy        String?   @map("deleted_by")

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("customer")
}

model PurchaseOrder {
  id                  BigInt    @id @default(autoincrement())
  tenantId            BigInt    @map("tenant_id")
  companyId           BigInt?   @map("company_id")
  orgId               BigInt?   @map("org_id")
  docNo               String    @map("doc_no")
  docDate             DateTime  @map("doc_date")
  status              String
  approvalStatus      String?   @map("approval_status")
  supplierId          BigInt?   @map("supplier_id")
  warehouseId         BigInt?   @map("warehouse_id")
  currency            String?   @default("CNY")
  exchangeRate        Decimal?  @map("exchange_rate") @db.Decimal(20, 8)
  taxIncluded         Boolean?  @map("tax_included")
  counterpartyId      String?   @map("counterparty_id")
  remarks             String?
  sourceRefType       String?   @map("source_ref_type")
  sourceRefId         String?   @map("source_ref_id")
  totalQty            Decimal   @default(0) @map("total_qty") @db.Decimal(20, 6)
  totalAmount         Decimal   @default(0) @map("total_amount") @db.Decimal(20, 6)
  taxAmount           Decimal   @default(0) @map("tax_amount") @db.Decimal(20, 6)
  totalWithTax        Decimal   @default(0) @map("total_with_tax") @db.Decimal(20, 6)
  expectedReceiptDate DateTime? @map("expected_receipt_date")
  ext                 Json?
  createdAt           DateTime  @default(now()) @map("created_at")
  createdBy           String    @default("system") @map("created_by")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  updatedBy           String    @default("system") @map("updated_by")
  deletedAt           DateTime? @map("deleted_at")
  deletedBy           String?   @map("deleted_by")

  @@unique([tenantId, docNo])
  @@index([tenantId, status, docDate])
  @@map("purchase_order")
}

model PurchaseOrderLine {
  id                BigInt   @id @default(autoincrement())
  tenantId          BigInt   @map("tenant_id")
  companyId         BigInt?  @map("company_id")
  orgId             BigInt?  @map("org_id")
  poId              BigInt   @map("po_id")
  lineNo            Int      @map("line_no")
  skuId             BigInt   @map("sku_id")
  itemNameSnapshot  String?  @map("item_name_snapshot")
  specModelSnapshot String?  @map("spec_model_snapshot")
  uom               String?
  qty               Decimal  @db.Decimal(20, 6)
  unitPrice         Decimal  @map("unit_price") @db.Decimal(20, 6)
  amount            Decimal  @db.Decimal(20, 6)
  taxRate           Decimal? @map("tax_rate") @db.Decimal(20, 6)
  taxAmount         Decimal? @map("tax_amount") @db.Decimal(20, 6)
  warehouseId       BigInt?  @map("warehouse_id")
  binId             BigInt?  @map("bin_id")
  batchNo           String?  @map("batch_no")
  serialNo          String?  @map("serial_no")
  sourceLineId      String?  @map("source_line_id")
  lineStatus        String?  @map("line_status")
  receivedQty       Decimal  @default(0) @map("received_qty") @db.Decimal(20, 6)
  acceptedQty       Decimal  @default(0) @map("accepted_qty") @db.Decimal(20, 6)
  rejectedQty       Decimal  @default(0) @map("rejected_qty") @db.Decimal(20, 6)
  ext               Json?
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([tenantId, poId, lineNo])
  @@index([tenantId, poId])
  @@map("purchase_order_line")
}

model GoodsReceipt {
  id             BigInt    @id @default(autoincrement())
  tenantId       BigInt    @map("tenant_id")
  companyId      BigInt?   @map("company_id")
  orgId          BigInt?   @map("org_id")
  docNo          String    @map("doc_no")
  docDate        DateTime  @map("doc_date")
  status         String
  approvalStatus String?   @map("approval_status")
  supplierId     BigInt?   @map("supplier_id")
  warehouseId    BigInt?   @map("warehouse_id")
  currency       String?   @default("CNY")
  exchangeRate   Decimal?  @map("exchange_rate") @db.Decimal(20, 8)
  taxIncluded    Boolean?  @map("tax_included")
  counterpartyId String?   @map("counterparty_id")
  remarks        String?
  sourceRefType  String?   @map("source_ref_type")
  sourceRefId    String?   @map("source_ref_id")
  totalQty       Decimal   @default(0) @map("total_qty") @db.Decimal(20, 6)
  totalAmount    Decimal   @default(0) @map("total_amount") @db.Decimal(20, 6)
  taxAmount      Decimal   @default(0) @map("tax_amount") @db.Decimal(20, 6)
  totalWithTax   Decimal   @default(0) @map("total_with_tax") @db.Decimal(20, 6)
  ext            Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  createdBy      String    @default("system") @map("created_by")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  updatedBy      String    @default("system") @map("updated_by")
  deletedAt      DateTime? @map("deleted_at")
  deletedBy      String?   @map("deleted_by")

  @@unique([tenantId, docNo])
  @@index([tenantId, status, docDate])
  @@map("goods_receipt")
}

model GoodsReceiptLine {
  id                BigInt   @id @default(autoincrement())
  tenantId          BigInt   @map("tenant_id")
  companyId         BigInt?  @map("company_id")
  orgId             BigInt?  @map("org_id")
  goodsReceiptId    BigInt   @map("goods_receipt_id")
  lineNo            Int      @map("line_no")
  itemId            BigInt   @map("item_id")
  itemNameSnapshot  String?  @map("item_name_snapshot")
  specModelSnapshot String?  @map("spec_model_snapshot")
  uom               String
  qty               Decimal  @db.Decimal(20, 6)
  unitPrice         Decimal? @map("unit_price") @db.Decimal(20, 6)
  taxRate           Decimal? @map("tax_rate") @db.Decimal(20, 6)
  amount            Decimal? @db.Decimal(20, 6)
  taxAmount         Decimal? @map("tax_amount") @db.Decimal(20, 6)
  warehouseId       BigInt?  @map("warehouse_id")
  binId             BigInt?  @map("bin_id")
  batchNo           String?  @map("batch_no")
  serialNo          String?  @map("serial_no")
  sourceLineId      String?  @map("source_line_id")
