{
  "name": "server",
  "version": "0.0.1",
  "description": "miniERP Backend - NestJS",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "bun run db:generate",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "bun --watch src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "bun run db:generate && eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "pretest": "bun run db:generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:tenant-tx": "bun run db:generate && jest --runInBand src/database/platform-db.integration.spec.ts",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "openapi:generate": "bun run scripts/generate-openapi.ts",
    "openapi:check": "bun run scripts/generate-openapi.ts && bun run scripts/check-openapi-quality.ts",
    "codemap:update": "bun run scripts/update-codemaps.ts",
    "codemap:report": "bun run scripts/update-codemaps.ts --dry-run --yes",
    "codemap:check": "bun run scripts/update-codemaps.ts --dry-run --threshold 0",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema ./prisma/schema.prisma",
    "db:seed": "node -r ts-node/register prisma/seed.ts",
    "tenant:migrate-all": "bun run scripts/tenant-migrations.ts migrate-all-tenants",
    "tenant:init": "bun run scripts/tenant-migrations.ts tenant-init"
  },
  "dependencies": {
    "@minierp/platform-db": "workspace:*",
    "@minierp/platform-tenant": "workspace:*",
    "@minierp/platform-policy": "workspace:*",
    "@minierp/platform-iam": "workspace:*",
    "@minierp/shared": "workspace:*",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "decimal.js": "^10.6.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "prisma": "^6.6.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
